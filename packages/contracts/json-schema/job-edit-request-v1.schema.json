{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lr-frameflow/job-edit-request-v1.schema.json",
  "title": "EditJobRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "photo_ids"],
  "properties": {
    "schema_version": { "const": "edit-request-v1" },
    "correlation_id": { "type": "string" },
    "profile_id": { "type": "string", "format": "uuid" },
    "collection_name": { "type": "string" },
    "photo_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uuid" }
    }
  }
}
