{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lr-frameflow/job-train-request-v1.schema.json",
  "title": "TrainJobRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_name", "genre", "format_type", "color_type", "photo_ids"],
  "properties": {
    "schema_version": { "const": "train-request-v1" },
    "correlation_id": { "type": "string" },
    "profile_name": { "type": "string", "minLength": 1 },
    "genre": { "type": "string", "minLength": 1 },
    "format_type": { "type": "string", "enum": ["raw", "jpeg_tiff"] },
    "color_type": { "type": "string", "enum": ["color", "bw"] },
    "photo_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uuid" }
    },
    "base_preset": {
      "type": "object",
      "additionalProperties": true,
      "description": "Neutral JSON anchor for deltas (Tone/Presence)."
    }
  }
}
